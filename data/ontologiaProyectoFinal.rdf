                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                        <rdf:first>
                                            <rdf:Description>
                                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                                                <swrl:propertyPredicate rdf:resource="http://www.semanticweb.org/carola/ontologies/2026/3/OntologiaUACM#interesadoEn"/>
                                                <swrl:argument1 rdf:resource="http://www.semanticweb.org/carola/ontologies/2026/3/OntologiaUACM/e"/>
                                                <swrl:argument2 rdf:resource="http://www.semanticweb.org/carola/ontologies/2026/3/OntologiaUACM/a"/>
