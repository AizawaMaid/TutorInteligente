    <rdf:Description>
        <swrla:isRuleEnabled rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</swrla:isRuleEnabled>
        <rdfs:comment>Se recomienda por el area de interes</rdfs:comment>
        <rdfs:label>Area</rdfs:label>
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Imp"/>
        <swrl:body>
            <rdf:Description>
                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                <rdf:first>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#ClassAtom"/>
                        <swrl:classPredicate rdf:resource="http://www.semanticweb.org/carola/ontologies/2026/3/OntologiaUACM#Estudiante"/>
                        <swrl:argument1 rdf:resource="http://www.semanticweb.org/carola/ontologies/2026/3/OntologiaUACM/e"/>
                    </rdf:Description>
                </rdf:first>
                <rdf:rest>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                        <rdf:first>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#ClassAtom"/>
                                <swrl:classPredicate rdf:resource="http://www.semanticweb.org/carola/ontologies/2026/3/OntologiaUACM#Materia_Optativa"/>
                                <swrl:argument1 rdf:resource="http://www.semanticweb.org/carola/ontologies/2026/3/OntologiaUACM/m"/>
                            </rdf:Description>
                        </rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                <rdf:first>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                                        <swrl:propertyPredicate rdf:resource="http://www.semanticweb.org/carola/ontologies/2026/3/OntologiaUACM#tiene"/>
                                        <swrl:argument1 rdf:resource="http://www.semanticweb.org/carola/ontologies/2026/3/OntologiaUACM/m"/>
